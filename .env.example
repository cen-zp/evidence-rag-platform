# API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
WEB_ORIGIN=http://localhost:3000

# Do not commit real values. Keep DEEPSEEK_API_KEY only in your local .env file.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# Data services
POSTGRES_DB=evidence_rag
POSTGRES_USER=evidence_rag
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgresql+psycopg://evidence_rag:change-me-locally@localhost:5432/evidence_rag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=document_chunks_bge_small_zh_v1_5
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
EMBEDDING_DEVICE=cpu
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_ENABLED=true
RERANKER_CANDIDATE_COUNT=10
RERANKER_DEVICE=cpu
